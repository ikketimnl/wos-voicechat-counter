# ── Discord Bot Configuration ─────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=your_guild_id_here

# ── TTS Provider ──────────────────────────────────────────────────────────────
# Switch at runtime via /settings in Discord — no restart needed.
# Options: local | espeak | festival | piper | console
TTS_PROVIDER=local

# ── Piper Neural TTS (only needed if TTS_PROVIDER=piper) ─────────────────────
# Path to the .onnx model file inside the container.
# See DOCKER.md for installation steps.
# PIPER_MODEL=/opt/piper/voices/en_US-lessac-medium.onnx
